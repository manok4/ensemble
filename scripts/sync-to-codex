#!/usr/bin/env bash
# sync-to-codex — symlink (or copy on Windows) Ensemble's skills/agents into ~/.codex/.
# Used by ./setup; can also be run standalone.
#
# Installs each skill folder and each agent file directly at the discovery root
# (~/.codex/skills/<skill>/SKILL.md, ~/.codex/agents/<agent>.md) — NOT nested
# under .../ensemble/, which would hide them from host discovery.

set -eu

SOURCE_DIR="${ENSEMBLE_SOURCE:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
TARGET_DIR="${HOME}/.codex"
MODE="${1:-symlink}"  # symlink or copy

if [ ! -d "$SOURCE_DIR/skills" ] || [ ! -d "$SOURCE_DIR/agents" ]; then
  echo "ERROR: $SOURCE_DIR doesn't look like an Ensemble checkout (missing skills/ or agents/)" >&2
  exit 2
fi

mkdir -p "$TARGET_DIR/skills" "$TARGET_DIR/agents"

manifest_dir="$HOME/.ensemble"
mkdir -p "$manifest_dir"
manifest_file="$manifest_dir/install-manifest-codex.txt"

# Sweep prior install entries, then re-create.
if [ -f "$manifest_file" ]; then
  while IFS= read -r prior_path; do
    [ -n "$prior_path" ] || continue
    if [ -L "$prior_path" ]; then
      rm -f "$prior_path"
    elif [ -e "$prior_path" ] && [ "$MODE" = "copy" ]; then
      rm -rf "$prior_path"
    fi
  done < "$manifest_file"
fi
: > "$manifest_file"

skill_count=0
for skill_path in "$SOURCE_DIR/skills"/*/; do
  [ -d "$skill_path" ] || continue
  skill_name="$(basename "$skill_path")"
  dst="$TARGET_DIR/skills/$skill_name"
  if [ -e "$dst" ] || [ -L "$dst" ]; then
    echo "  ⚠ $dst already exists (not from a prior Ensemble install); skipping" >&2
    continue
  fi
  if [ "$MODE" = "copy" ]; then
    cp -R "$skill_path" "$dst"
  else
    ln -s "${skill_path%/}" "$dst"
  fi
  echo "$dst" >> "$manifest_file"
  skill_count=$((skill_count + 1))
done

agent_count=0
for agent_file in "$SOURCE_DIR/agents"/*.md; do
  [ -f "$agent_file" ] || continue
  agent_name="$(basename "$agent_file")"
  dst="$TARGET_DIR/agents/$agent_name"
  if [ -e "$dst" ] || [ -L "$dst" ]; then
    echo "  ⚠ $dst already exists; skipping" >&2
    continue
  fi
  if [ "$MODE" = "copy" ]; then
    cp "$agent_file" "$dst"
  else
    ln -s "$agent_file" "$dst"
  fi
  echo "$dst" >> "$manifest_file"
  agent_count=$((agent_count + 1))
done

echo "Synced to $TARGET_DIR ($MODE): $skill_count skill(s), $agent_count agent(s)"

if ! command -v codex >/dev/null 2>&1; then
  echo ""
  echo "Note: codex CLI not found on PATH. Skills and agents are in place; install codex when ready." >&2
fi
